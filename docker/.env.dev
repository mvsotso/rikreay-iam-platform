# =============================================================================
# RikReay IAM Platform — DEV Environment Variables
# These are dev-only secrets — safe to check into git.
# =============================================================================

SPRING_PROFILES_ACTIVE=dev

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=iam_admin
POSTGRES_PASSWORD=iam_secret_2026

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=redis_secret_2026

# Kafka
KAFKA_SERVERS=localhost:9092

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=iam-platform
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:5173

# Mailpit (dev SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025

# Vault
VAULT_TOKEN=iam-dev-root-token
VAULT_ADDR=http://localhost:8200

# Telegram (disabled in dev)
TELEGRAM_BOT_TOKEN=disabled
