# =============================================================================
# RikReay IAM Platform — PROD Environment Variables
# Copy to .env.prod and fill in real values. Do NOT commit .env.prod to git.
# Production MUST be on Cambodia-based infrastructure (LPDP Articles 22, 24).
# =============================================================================

SPRING_PROFILES_ACTIVE=prod

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_USER=iam_admin
POSTGRES_PASSWORD=CHANGE_ME_PROD_STRONG_DB_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_PROD_STRONG_REDIS_PASSWORD

# Kafka
KAFKA_SERVERS=kafka:29092

# Keycloak
KEYCLOAK_URL=https://rikreay.duckdns.org/auth
KEYCLOAK_REALM=iam-platform
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_PROD_STRONG_KC_PASSWORD

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# CORS
CORS_ORIGINS=https://rikreay.duckdns.org

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_PROD_STRONG_GRAFANA_PASSWORD

# SMTP (production mail server)
SMTP_HOST=CHANGE_ME_PROD_SMTP_HOST
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_PROD_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_PROD_SMTP_PASSWORD

# Vault (production — use auto-unseal, NOT dev mode)
VAULT_TOKEN=CHANGE_ME_PROD_VAULT_TOKEN
VAULT_ADDR=http://vault:8200

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME_PROD_TELEGRAM_TOKEN

# DuckDNS (migrate to official domain later)
DUCKDNS_TOKEN=YOUR_DUCKDNS_TOKEN
