    "host": "mailpit",
    "port": "1025",
    "from": "noreply@iam-platform.local",
    "fromDisplayName": "RikReay IAM Platform",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "km"],
  "defaultLocale": "en",
