{
  "realm": "iam-platform",
  "displayName": "RikReay IAM Enterprise Platform",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "maxDeltaTimeSeconds": 600,
  "maxFailureWaitSeconds": 1800,
  "accessTokenLifespan": 600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "defaultSignatureAlgorithm": "RS256",
  "passwordPolicy": "length(8) and digits(1) and upperCase(1) and lowerCase(1) and specialChars(1) and notUsername and passwordHistory(3)",
